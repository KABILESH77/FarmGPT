# ==========================================
# FarmGPT Environment Configuration
# Copy this file to .env and fill in your keys
# ==========================================

# 1. Google AI Studio API Key (for Gemini translation engine)
# Get your free key here: https://aistudio.google.com/app/apikey
VITE_GOOGLE_TRANSLATE_API_KEY=your_gemini_api_key_here

# 2. Groq API Key (for Digital Krishi Officer Chatbot)
# Get your free key here: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here
